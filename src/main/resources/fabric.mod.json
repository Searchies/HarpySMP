{
  "schemaVersion": 1,
  "id": "harpysmp",
  "version": "${version}",
  "name": "HarpySMP",
  "description": "",
  "authors": ["agmass", "Searchies"],
  "contact": {},
  "license": "LGPL-3.0",
  "icon": "assets/harpysmp/icon.png",
  "environment": "*",
  "entrypoints": {
    "fabric-datagen": [
      "org.agmas.harpysmp.client.HarpySMPDataGenerator"
    ],
    "client": [
      "org.agmas.harpysmp.client.HarpySMPClient"
    ],
    "cardinal-components": [
      "org.agmas.harpysmp.components.HarpySMPComponents"
    ],
    "main": [
      "org.agmas.harpysmp.HarpySMP"
    ]
  },

  "custom": {
    "cardinal-components": [
      "harpysmp:lives",
      "harpysmp:deathban"
    ]
  },
  "mixins": [
    "harpysmp.mixins.json",
    {
      "config": "harpysmp.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-api": "*",
    "minecraft": "${minecraft_version}"
  }
}
